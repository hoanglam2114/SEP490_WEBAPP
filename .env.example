# ============================================================
# SEP490 WEBAPP — Environment Variables
# Sao chép file này thành .env và điền giá trị thực:
#   cp .env.example .env
#   nano .env
# ============================================================

# ── GPU Service ──────────────────────────────────────────────
# Anthropic API Key (dùng cho Claude LLM Judge trong eval)
ANTHROPIC_API_KEY=sk-ant-...

# HuggingFace Token (để push/pull model từ HF Hub)
HF_TOKEN=hf_...

# ── Backend ──────────────────────────────────────────────────
# DeepSeek API Key
DEEPSEEK_API_KEY=...

# Google Gemini API Key
GEMINI_API_KEY=...

# OpenAI-compatible API (mặc định dùng Groq)
OPENAI_API_KEY=gsk_...
OPENAI_BASE_URL=https://api.groq.com/openai/v1
OPENAI_MODEL=llama-3.3-70b-versatile

# Google Drive (JSON service account, 1 dòng)
GOOGLE_DRIVE_CREDENTIALS={"type":"service_account",...}
GOOGLE_DRIVE_FOLDER_ID=...
