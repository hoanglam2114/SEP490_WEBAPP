# ============================================================
# GPU Service — Environment Variables
# Sao chép file này thành .env và điền giá trị thực
#   cp .env.example .env
# ============================================================

# Địa chỉ backend của project (để GPU service callback về)
BACKEND_URL=http://your-backend-server:3000

# Anthropic API Key (dùng cho Claude LLM Judge trong eval)
ANTHROPIC_API_KEY=sk-ant-...

# HuggingFace Token (để push/pull model từ HF Hub)
HF_TOKEN=hf_...

# Flask server config (thường không cần đổi)
HOST=0.0.0.0
PORT=5000
